          "param": "email@example.com",
          "description": "发送邮件到指定地址"
        },
        {
          "param": "?subject=&body=",
          "description": "带主题和正文的邮件"
        }
      ],
      "example": "mailto:test@example.com?subject=Hello&body=This is a test"
    },
    {
      "app_name": "FaceTime",
      "bundle_id": "com.apple.facetime",
