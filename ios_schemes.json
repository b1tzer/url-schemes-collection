      "bundle_id": "com.apple.Maps",
      "scheme": "maps://",
      "description": "iOS 地图应用 URL Scheme",
      "parameters": [
        {
          "param": "q=",
          "description": "搜索位置"
        },
        {
          "param": "ll=",
          "description": "指定经纬度"
        }
      ],
      "example": "maps://q=北京天安门"
    },
    {
