{
  "ios_system": [
    {
      "app_name": "设置",
      "bundle_id": "com.apple.Preferences",
      "scheme": "prefs://",
      "description": "iOS 设置应用 URL Scheme",
      "parameters": [
        {
          "param": "General",
          "description": "通用设置"
        },
        {
          "param": "Bluetooth",
          "description": "蓝牙设置"
        },
        {
          "param": "Cellular",
          "description": "蜂窝移动网络设置"
        },
        {
          "param": "Wi-Fi",
          "description": "Wi-Fi设置"
        },
        {
          "param": "Display & Brightness",
          "description": "显示与亮度设置"
        }
      ],
      "example": "prefs://General"
    },
    {
      "app_name": "日历",
      "bundle_id": "com.apple.mobilecal",
      "scheme": "calshow://",
      "description": "iOS 日历应用 URL Scheme",
      "parameters": [
        {
          "param": "时间戳",
          "description": "打开指定日期"
        }
      ],
      "example": "calshow://1609459200"
    },
    {
